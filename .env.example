# LinkedIn Configuration
LINKEDIN_EMAIL=your_email@gmail.com
LINKEDIN_PASSWORD=your_password
LINKEDIN_COOKIE_JAR=linkedin_cookies.json

# Indeed Configuration
INDEED_API_KEY=your_indeed_api_key

# Naukri Configuration
NAUKRI_API_KEY=your_naukri_api_key

# AngelList Configuration
ANGELLIST_API_KEY=your_angellist_api_key

# Database Configuration
DB_PATH=data/jobs_database.json
NOTIFICATION_DB=data/notifications.json
SPAM_LIST_DB=data/spam_list.json

# Email Notifications
NOTIFICATION_EMAIL=your_email@gmail.com
NOTIFICATION_EMAIL_PASSWORD=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Application Settings
DEBUG=True
FLASK_ENV=development
SECRET_KEY=your_secret_key_here

# Scraping Configuration
REQUEST_TIMEOUT=10
RETRY_ATTEMPTS=3
RETRY_DELAY=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
